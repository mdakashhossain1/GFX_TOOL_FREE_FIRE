<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:fitsSystemWindows="true"
    android:id="@+id/drawer_layout"
    android:background="#E4E6E5"
    tools:openDrawer="start">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="66dp"
            android:background="#33B5A3"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Icon -->
                <ImageView
                    android:id="@+id/menu"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/menu"
                    android:layout_marginRight="12dp"
                    android:contentDescription="Menu Icon" />

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/app_name"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>


            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/gradient_background"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <com.facebook.ads.NativeAdLayout
                    android:id="@+id/nativeadd"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="31dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="All tools settings"
                android:textColor="@color/white"
                android:background="@color/primary"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:gravity="center"
                android:textAllCaps="true"
                android:textSize="19sp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginTop="1dp"
                android:layout_marginBottom="16dp"
                android:padding="5dp">

                <!-- Headshot Card -->
                <LinearLayout
                    android:id="@+id/headshoot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_corners"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/headshot_main" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEADSHOT"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#00796B"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Perfect settings for you"
                        android:textSize="12sp"
                        android:textColor="#8E8E8E" />
                </LinearLayout>

                <!-- Evo H4X Card -->
                <LinearLayout
                    android:id="@+id/evoskin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_corners"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/evo_h4x" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EVO H4X"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#00796B"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The best h4x tools"
                        android:textSize="12sp"
                        android:textColor="#8E8E8E" />
                </LinearLayout>

                <!-- Grand Push Card -->
                <LinearLayout
                    android:id="@+id/grandpush"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_corners"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/grand_push" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GRAND PUSH"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#00796B"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Best tool for rank push"
                        android:textSize="12sp"
                        android:textColor="#8E8E8E" />
                </LinearLayout>

                <!-- Red Custom Card -->
                <LinearLayout
                    android:id="@+id/redcustom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_corners"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/red_custom" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RED CUSTOM"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#00796B"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Custom king setting"
                        android:textSize="12sp"
                        android:textColor="#8E8E8E" />
                </LinearLayout>

                <!-- One Tap -->
                <LinearLayout
                    android:id="@+id/onetap"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_corners"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/onetap_main" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ONE TAP"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#00796B"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amazing onetap options"
                        android:textSize="12sp"
                        android:textColor="#8E8E8E" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/gloowall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/rounded_corners"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/gloo_main" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FAST GLOO"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#00796B"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enhance gloo speed"
                        android:textSize="12sp"
                        android:textColor="#8E8E8E" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/play_now"
                    android:layout_width="0dp"
                    android:layout_height="300dp"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@drawable/play_now"
                    android:layout_columnWeight="1"/>

                <LinearLayout
                    android:id="@+id/discover_play_now"
                    android:layout_width="0dp"
                    android:layout_height="300dp"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:background="@drawable/discover_play_now"
                    android:gravity="center"
                    android:padding="8dp"
                    android:layout_columnWeight="1"/>

            </GridLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
